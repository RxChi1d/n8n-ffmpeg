ARG N8N_VERSION=latest
# Pins only the donor stage that provides apk.static and signing keys (both
# work across newer Alpine releases); the runtime package repositories are
# detected from the base image instead.
ARG ALPINE_VERSION=3.22

FROM alpine:${ALPINE_VERSION} AS apktools
RUN apk add --no-cache apk-tools-static

FROM n8nio/runners:${N8N_VERSION}

USER root

# The runners image removes apk, so we bring back a working one. We do NOT
# reinstall the apk-tools package from the CDN: hardened bases pin every
# package in /etc/apk/world to an exact content hash, and Alpine's main repo
# only keeps the latest point release, so once the CDN bumps apk-tools a
# reinstall pulls a libapk2 that no longer matches the pin and the build
# breaks. Instead we keep the static apk binary from the donor stage as
# /sbin/apk: it never touches the pinned packages, installs ffmpeg cleanly,
# and leaves users a working apk for adding their own packages at runtime.
# The Alpine version is detected from /etc/os-release (works on both regular
# Alpine and hardened bases that drop /etc/alpine-release).
COPY --from=apktools /sbin/apk.static /sbin/apk.static
COPY --from=apktools /etc/apk/keys /tmp/apk-keys
RUN RUNTIME_ALPINE_VERSION=$(. /etc/os-release && printf '%s' "$VERSION_ID" | cut -d. -f1,2) \
    && [ -n "$RUNTIME_ALPINE_VERSION" ] \
    && mkdir -p /etc/apk /etc/apk/keys \
    && { cp -n /tmp/apk-keys/* /etc/apk/keys/ || true; } \
    && printf 'https://dl-cdn.alpinelinux.org/alpine/v%s/main\nhttps://dl-cdn.alpinelinux.org/alpine/v%s/community\n' "$RUNTIME_ALPINE_VERSION" "$RUNTIME_ALPINE_VERSION" > /etc/apk/repositories \
    && /sbin/apk.static add --no-cache ffmpeg ffmpeg-dev \
    && mv /sbin/apk.static /sbin/apk \
    && rm -rf /tmp/apk-keys /var/cache/apk/*

# Make the Code Node module allowlists configurable via container env vars:
# the stock config hardcodes them in env-overrides (which silently discards
# user-provided values), so move them to allowed-env (passthrough) instead.
RUN python3 - <<'EOF'
import json

PATH = '/etc/n8n-task-runners.json'
MOVE = {
    'javascript': ['NODE_FUNCTION_ALLOW_BUILTIN', 'NODE_FUNCTION_ALLOW_EXTERNAL'],
    'python': ['N8N_RUNNERS_STDLIB_ALLOW', 'N8N_RUNNERS_EXTERNAL_ALLOW'],
}

with open(PATH) as f:
    config = json.load(f)

for runner in config['task-runners']:
    for key in MOVE.get(runner['runner-type'], []):
        if key not in runner.setdefault('allowed-env', []):
            runner['allowed-env'].append(key)
        runner.get('env-overrides', {}).pop(key, None)

with open(PATH, 'w') as f:
    json.dump(config, f, indent=2)
EOF

# Defaults match the stock image; override at runtime to allowlist more
# modules, e.g. NODE_FUNCTION_ALLOW_BUILTIN=crypto,child_process for ffmpeg.
ENV NODE_FUNCTION_ALLOW_BUILTIN=crypto \
    NODE_FUNCTION_ALLOW_EXTERNAL=moment \
    N8N_RUNNERS_STDLIB_ALLOW= \
    N8N_RUNNERS_EXTERNAL_ALLOW=

# Switch back to the default user.
USER runner

# Verify ffmpeg.
RUN ffmpeg -version \
    && ffprobe -version
